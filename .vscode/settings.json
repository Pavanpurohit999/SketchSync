{
    "window.autoDetectColorScheme": false,
    "window.closeWhenEmpty": false,
    "workbench.activityBar.iconClickBehavior": "toggle",
    "workbench.colorTheme": "Vira Ocean High Contrast",
    "workbench.statusBar.visible": true,
    "workbench.view.alwaysShowHeaderActions": false,
    "workbench.view.showQuietly": {
        "workbench.panel.output": false
    },
    "breadcrumbs.enabled": false,
    "breadcrumbs.filePath": "off",
    "breadcrumbs.icons": true,
    "workbench.editor.centeredLayoutFixedWidth": false,
    "workbench.editor.decorations.badges": true,
    "thunder-client.sidebar.defaultTab": "Activity",
    "thunder-client.sidebar.layout": "standard",
    "workbench.secondarySideBar.forceMaximized": false,
    "a-file-icon-vscode.arrowTheme": "triangle"
}